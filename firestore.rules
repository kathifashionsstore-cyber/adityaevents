rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read for site content
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['superadmin', 'manager'];
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    match /packages/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bookings/{docId} {
      allow create: if true;  // Anyone can create a booking
      allow read, update, delete: if request.auth != null;
    }

    match /customers/{docId} {
      allow create: if true;
      allow read, update: if request.auth != null || request.auth.uid == docId;
      allow delete: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin';
    }

    match /payments/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /expenses/{docId} {
      allow read, write: if request.auth != null;
    }

    match /staff/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['superadmin', 'manager'];
    }

    match /admins/{docId} {
      allow read: if request.auth != null && (
        request.auth.uid == docId ||
        resource.data.email == request.auth.token.email ||
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin'
      );
      allow write: if request.auth != null && (
        (request.auth.uid == docId && request.auth.token.email == 'admin@adithyaevents.com') ||
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin'
      );
    }

    match /inquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /coupons/{docId} {
      allow read: if true;  // clients validate on frontend
      allow write: if request.auth != null;
    }

    match /blogs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /faqs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /notifications/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true);
      allow write: if request.auth != null;
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /referrals/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if request.auth != null;
    }

    match /leads/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /festivalBanners/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /heroBanners/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    match /brochures/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /chatMessages/{docId} {
      allow read, write: if true;
    }

    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    match /activityLogs/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
    }
  }
}
