rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024;
    }
    match /testimonials/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /brochures/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /festivalBanners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroBanners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
    match /receipts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /staffPhotos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /siteAssets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
